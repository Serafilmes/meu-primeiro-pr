# Variáveis de ambiente (segredos — nunca versionar)
.env

# Credenciais da conta de serviço do Google (chave privada — NUNCA versionar)
credenciais_google.json
*credentials*.json
*-service-account*.json

# Banco de dados local (é operacional, não vai para o repositório).
# O padrão sem barra pega gma.db em qualquer nível (inclui projetos/*/gma.db).
gma.db
gma.db-shm
gma.db-wal
gma.db.bak_*

# Sentinelas de runtime (ativação + sinais do Painel de Controle, Camada 5)
.gma_ativo
.gma_reiniciar
.gma_encerrar
.gma_maestro.lock
.gma_saguao.lock

# Arquivos do macOS
.DS_Store

# Filas, contadores e estado do painel (runtime — por máquina E por projeto).
# Pastas inteiras: cobre os backups (_arquivo_*/) e as filas isoladas por projeto
# (projetos/<slug>/fila_*, .../contadores). Nada de runtime vai para o repositório.
fila_forms/
fila_material/
contadores/
**/fila_forms/
**/fila_material/
**/contadores/
painel_estado.json
logs/*.log
logs/*.out
logs/backup_*

# Config local do Claude Code (específica desta máquina — não versionar)
.claude/settings.local.json

# Material de teste (mídia — insubstituível, pesada, nunca vai para o repositório)
TESTE LOGAGEM/

# Destino por-projeto (GMA_DESTINO) — mídia copiada dos cartões; mesma regra: fora do repo
PROJETO/

# Pasta satélite de recebidos (staging de material que NÃO vem por cartão — mídia, fora do repo)
RECEBIDOS/

# Miniaturas geradas pelo extrator de frames (saída operacional, recriável)
_GMA_frames/
*_manifesto.json

# Lixo de build do Python
__pycache__/
*.pyc

# Caixa isolada da IA (Camada 6) — bibliotecas pesadas do Whisper (faster-whisper).
# Recriável: python3 -m venv .venv_ia && .venv_ia/bin/pip install faster-whisper
.venv_ia/
